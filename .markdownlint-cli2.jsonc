{
  // markdownlint-cli2 configuration for nordic-mcp
  "config": {
    "default": true,
    // Allow long lines in tables and code blocks
    "MD013": false,
    // Allow duplicate headings in different sections
    "MD024": { "siblings_only": true },
    // Allow bare URLs (used in reference sections)
    "MD034": false,
    // Allow inline HTML (used sparingly)
    "MD033": false
  },
  "ignores": [
    "node_modules/**",
    "container/mcp-server/node_modules/**"
  ]
}
