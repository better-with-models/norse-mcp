# nordic-mcp environment configuration
# Copy this file to .env and fill in real values before starting the stack.
# NEVER commit .env to version control.

# ── Data storage ─────────────────────────────────────────────────────────────
# Directory where OpenViking persists its vector database.
# Must be writable by the Docker user. Created automatically if it doesn't exist.
NORDIC_MCP_DATA=${HOME}/.nordic_mcp/openviking-data

# ── OpenViking HTTP server ────────────────────────────────────────────────────
OPENVIKING_PORT=1933
OPENVIKING_STORAGE_WORKSPACE=/app/data/workspace
OPENVIKING_LOG_LEVEL=INFO
OPENVIKING_LOG_OUTPUT=stdout

# ── Authentication ────────────────────────────────────────────────────────────
# Root API key for OpenViking REST API and MCP server.
# All client calls must include: Authorization: Bearer <value>
OPENVIKING_ROOT_API_KEY=change-me

# ── OpenAI-compatible endpoint (required for embeddings and VLM) ─────────────
# This can be the public OpenAI API or a local OpenAI-compatible server such as
# LM Studio. If you are using a local server, also update the *_API_BASE,
# *_MODEL, and *_DIMENSION values below to match the loaded models.
OPENAI_API_KEY=

# ── Embedding model ───────────────────────────────────────────────────────────
# WARNING: Changing these after data is stored will break existing collections.
OPENVIKING_EMBED_API_BASE=https://api.openai.com/v1
OPENVIKING_EMBED_API_KEY=
OPENVIKING_EMBED_PROVIDER=openai
OPENVIKING_EMBED_DIMENSION=3072
OPENVIKING_EMBED_MODEL=text-embedding-3-large

# ── Vision-language model ─────────────────────────────────────────────────────
OPENVIKING_VLM_API_BASE=https://api.openai.com/v1
OPENVIKING_VLM_API_KEY=
OPENVIKING_VLM_PROVIDER=openai
OPENVIKING_VLM_MODEL=gpt-4-vision-preview
OPENVIKING_VLM_MAX_CONCURRENT=100

# ── OpenViking MCP — co-located in the nordic-mcp container ──────────────────
# OPENVIKING_INTERNAL_PORT: port openviking-server binds on internally
# (nginx takes the public port defined by OPENVIKING_PORT above).
OPENVIKING_VERSION=v0.2.9
OPENVIKING_INTERNAL_PORT=1934
# Default collection path and optional index name used by the MCP tools.
OPENVIKING_COLLECTION_PATH=/
OPENVIKING_INDEX_NAME=
